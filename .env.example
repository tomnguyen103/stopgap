# --- Stopgap environment (copy to .env; .env is gitignored) ---

# Postgres (app DB). docker-compose provisions this locally.
DATABASE_URL=postgres://stopgap:stopgap@localhost:5433/stopgap

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=stopgap-cases

# --- LLM provider routing ---
# Prod default. If GEMINI_API_KEY is absent, the Gemini provider is stubbed and
# routing falls back to Ollama (see PHASE5-TODO.md).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash-lite

# Local dev / CI / runtime fallback. Ollama must be running locally.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Provider preference: "gemini" (prod) or "ollama" (dev/ci). CI sets "ollama".
LLM_PROVIDER=ollama

# --- Feeds (all REAL, live; no key required) ---
OPENFDA_BASE_URL=https://api.fda.gov
# openFDA allows more requests/day with a free key; optional.
OPENFDA_API_KEY=
RXNORM_BASE_URL=https://rxnav.nlm.nih.gov
ASHP_FEED_URL=https://raw.githubusercontent.com/ASHP-Software/drugShortagesDoc/master

# --- Observability (Phase 2) ---
LANGFUSE_BASE_URL=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Outbound comms (Phase 4). Stubbed if absent. ---
RESEND_API_KEY=
COMMS_FROM=stopgap@example.com
COMMS_DEMO_INBOX=

# Mock EHR formulary-flag webhook (Phase 4)
EHR_WEBHOOK_URL=http://localhost:4000/ehr/formulary-flag
