# --- Stopgap environment (copy to .env; .env is gitignored) ---

# Postgres (app DB). docker-compose provisions this locally.
DATABASE_URL=postgres://stopgap:stopgap@localhost:5433/stopgap

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=stopgap-cases

# --- LLM provider routing ---
# Prod default. If GEMINI_API_KEY is absent, the Gemini provider is stubbed and
# routing falls back to Ollama (see PHASE5-TODO.md).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash-lite

# Local dev / CI / runtime fallback. Ollama must be running locally.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Provider preference: "gemini" (prod) or "ollama" (dev/ci). CI sets "ollama".
LLM_PROVIDER=ollama

# --- Feeds (all REAL, live; no key required) ---
OPENFDA_BASE_URL=https://api.fda.gov
# openFDA allows more requests/day with a free key; optional.
OPENFDA_API_KEY=
RXNORM_BASE_URL=https://rxnav.nlm.nih.gov
ASHP_FEED_URL=https://raw.githubusercontent.com/ASHP-Software/drugShortagesDoc/master

# --- Observability (Phase 2) ---
# Tracing stays OFF unless both keys are set. Self-hosted Langfuse:
#   docker compose --profile langfuse up -d
# seeds this local project (see docker-compose.yml LANGFUSE_INIT_*), UI on :3001.
LANGFUSE_BASE_URL=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Outbound comms (Phase 4). Stubbed if absent. ---
# Without RESEND_API_KEY the send is recorded as a non-delivery (with the reason) rather than
# faked as a success. COMMS_PHARMACY_TO is the real distribution list, comma-separated;
# COMMS_DEMO_INBOX is the single-address demo fallback.
RESEND_API_KEY=
COMMS_FROM=stopgap@example.com
COMMS_PHARMACY_TO=
COMMS_DEMO_INBOX=

# Mock EHR formulary-flag webhook (Phase 4)
EHR_WEBHOOK_URL=http://localhost:4000/ehr/formulary-flag

# --- Demo mode (Phase 5, PROJECT_PLAN §11). Off locally; the VPS deploy turns it on. ---
# "on" = public read-only console: reviews/exception resolutions are refused server-side and
# the only visitor mutation is "Run a shortage" (fixed drug catalogue, rate limited).
STOPGAP_DEMO_MODE=off
# Hard daily LLM spend cap in USD. Over it, routing falls back to the free local model and the
# console banner says so. Spend is accumulated in the `llm_spend` table.
DEMO_DAILY_USD_CAP=2
DEMO_MAX_RUNS_PER_HOUR=6
