{
  "name": "shadow-ledger",
  "version": "0.1.0",
  "description": "Score an agent against a human baseline, aggregate per cohort, and gate autonomy on measured agreement.",
  "keywords": [
    "shadow-mode",
    "evaluation",
    "agents",
    "llm",
    "promotion-gates",
    "human-in-the-loop"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build",
    "prepublishOnly": "node -e \"if(!(process.env.npm_config_user_agent||'').startsWith('pnpm'))throw new Error('publish with pnpm, not npm — see PUBLISHING.md (npm ignores publishConfig main/types/exports)')\""
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  }
}
