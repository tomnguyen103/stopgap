# Stopgap VPS deployment — copy to deploy/.env and fill in. Never commit the filled file.
# Generate every secret below with `openssl rand -hex 32` unless noted otherwise.

# --- domains (point A/AAAA records at the VPS before starting Caddy) ---
APP_DOMAIN=stopgap.example.com
TEMPORAL_DOMAIN=temporal.stopgap.example.com
TRACES_DOMAIN=traces.stopgap.example.com

# Basic auth for the Temporal UI and Langfuse. Hash: `caddy hash-password --plaintext '<pw>'`
# IMPORTANT: docker compose interpolates `$` in this file, so DOUBLE every `$` in the bcrypt
# hash ($2a$14$... becomes $$2a$$14$$...). Unescaped, compose eats the segments and Caddy
# starts with a truncated hash that no password matches.
BASIC_AUTH_USER=viewer
BASIC_AUTH_HASH=$$2a$$14$$replace_with_a_real_bcrypt_hash

# --- datastores ---
POSTGRES_PASSWORD=
CLICKHOUSE_PASSWORD=
REDIS_PASSWORD=
MINIO_USER=stopgap
MINIO_PASSWORD=

# --- Langfuse ---
LANGFUSE_SALT=
# Must be exactly 64 hex characters.
LANGFUSE_ENCRYPTION_KEY=
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_ADMIN_EMAIL=you@example.com
LANGFUSE_ADMIN_PASSWORD=
# These two also go to the app as its tracing credentials; any stable strings work.
LANGFUSE_PUBLIC_KEY=pk-lf-stopgap-prod
LANGFUSE_SECRET_KEY=

# --- model routing ---
# "gemini" spends money and needs GEMINI_API_KEY; "ollama" is free and runs in-cluster on CPU.
LLM_PROVIDER=ollama
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash-lite
OLLAMA_MODEL=mistral

# --- demo mode (PROJECT_PLAN §11) ---
# "on" = public read-only demo: reviews/exception resolutions refused, "Run a shortage" allowed.
STOPGAP_DEMO_MODE=on
# Daily LLM spend cap in USD, applied to every caller (visitors and scheduled polls alike).
# Over it, routing is restricted to the free local model and the console banner says so.
# Leave unset for no cap.
LLM_DAILY_USD_CAP=2   # blank = no cap
DEMO_MAX_RUNS_PER_HOUR=6

# --- optional integrations (each degrades honestly when absent) ---
OPENFDA_API_KEY=
ASHP_AUTH_KEY=
RESEND_API_KEY=
COMMS_FROM=stopgap@example.com
COMMS_PHARMACY_TO=
COMMS_DEMO_INBOX=
EHR_WEBHOOK_URL=
